                MX6UL_PAD_LCD_DATA02__I2C4_SDA             0x000010B0
                MX6UL_PAD_LCD_DATA03__I2C4_SCL             0x000010B0
                MX6UL_PAD_LCD_DATA16__UART7_DCE_TX         0x000010B0
                MX6UL_PAD_LCD_DATA17__UART7_DCE_RX         0x000010B0
