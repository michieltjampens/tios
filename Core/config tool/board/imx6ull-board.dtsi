                MX6UL_PAD_LCD_DATA23__ECSPI1_MISO          0x000010B0
                MX6UL_PAD_SD1_CLK__USDHC1_CLK              0x000010B0
                MX6UL_PAD_SD1_CMD__USDHC1_CMD              0x000010B0
