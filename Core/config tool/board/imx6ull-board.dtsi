/dts-v1/;

#include "skeleton.dtsi"
#include "imx6ull-pinfunc.h"
#include "imx6ull-pinfunc-snvs.h"

/ {
    model = "NXP i.MX 6ULL User Board";
    compatible = "fsl,imx6ull-board", "fsl,imx6ull";

    soc {
        #address-cells = <1>;
        #size-cells = <1>;

        iomuxc: iomuxc@020e0000 {
            compatible = "fsl,imx6ull-iomuxc";
            reg = <0x020e0000 0x4000>;
        };

        iomuxc_snvs: iomuxc-snvs@02290000 {
            compatible = "fsl,imx6ull-iomuxc_snvs";
            reg = <0x02290000 0x4000>;
        };
    };
};

&iomuxc {
    pinctrl-names = "default";
    pinctrl-0 = <&BOARD_InitPins>;
    imx6ull-board {
        BOARD_InitPins: BOARD_InitPinsGrp {                /*!< Function assigned for the core: Cortex-A7[ca7] */
            fsl,pins = <
                MX6UL_PAD_CSI_DATA00__ECSPI2_SCLK          0x000010B0
                MX6UL_PAD_CSI_DATA01__ECSPI2_SS0           0x000010B0
                MX6UL_PAD_CSI_DATA02__ECSPI2_MOSI          0x000010B0
                MX6UL_PAD_CSI_DATA03__ECSPI2_MISO          0x000010B0
                MX6UL_PAD_CSI_DATA05__USDHC1_CD_B          0x000010B0
                MX6UL_PAD_CSI_MCLK__UART6_DCE_TX           0x000010B0
                MX6UL_PAD_CSI_PIXCLK__UART6_DCE_RX         0x000010B0
                MX6UL_PAD_GPIO1_IO00__I2C2_SCL             0x000010B0
                MX6UL_PAD_GPIO1_IO01__I2C2_SDA             0x000010B0
                MX6UL_PAD_GPIO1_IO02__I2C1_SCL             0x000010B0
